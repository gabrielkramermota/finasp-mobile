{
  "name": "finasp",
  "version": "1.0.0",
  "scripts": {
    "android": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-android.ps1",
    "android:emulator": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-android.ps1 -StartEmulator",
    "android:boot-emulator": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-android.ps1 -StartEmulator -SkipExpo",
    "android:env": "powershell -ExecutionPolicy Bypass -File .\\scripts\\android-env.ps1 -PrintSummary",
    "build:android:preview": "npx eas build --platform android --profile preview",
    "build:android:production": "npx eas build --platform android --profile production",
    "build:configure": "npx eas build:configure",
    "build:ios:preview": "npx eas build --platform ios --profile preview",
    "build:ios:production": "npx eas build --platform ios --profile production",
    "doctor": "npx expo-doctor",
    "ios": "expo start --ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-file-system": "~19.0.23",
    "expo-image-picker": "~17.0.11",
    "expo-notifications": "~0.32.17",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~3.0.8",
    "lucide-react-native": "^1.21.0",
    "nativewind": "preview",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css": "latest",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "postcss": "^8.5.8",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.9"
  },
  "main": "node_modules/expo/AppEntry.js",
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "private": true
}
